{
  "name": "header-file-generator",
  "displayName": "Header File Generator",
  "description": "Automatically generates C/C++ header files (.h) from source files (.c / .cpp)",
  "version": "1.0.0",
  "publisher": "header-file-generator",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/ka1rav6/header-file-generator.git"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "C",
    "C++",
    "header",
    "generator",
    "hpp",
    ".h"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "headerFileGenerator.generate",
        "title": "Generate Header File",
        "category": "Header File Generator",
        "icon": "$(file-add)"
      }
    ],
    "keybindings": [
      {
        "command": "headerFileGenerator.generate",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "editorLangId == c || editorLangId == cpp"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "headerFileGenerator.generate",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "1_modification"
        }
      ],
      "explorer/context": [
        {
          "command": "headerFileGenerator.generate",
          "when": "resourceExtname == .c || resourceExtname == .cpp",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "headerFileGenerator.generate",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/vsce": "^3.8.0",
    "vsce": "^2.15.0"
  }
}
